# Server A — PSK secrets
#
# Deploy to: /etc/ipsec.d/site-to-site.secrets
# Set permissions: chmod 600
#
# Replace A.A.A.A with Server A's IP
# Replace B.B.B.B with Server B's IP
# Replace REPLACE_PSK_HERE with output of: openssl rand -hex 32
# This file must be identical on both servers.

A.A.A.A B.B.B.B : PSK "REPLACE_PSK_HERE"
